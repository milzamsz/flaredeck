{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlareDeck",
  "version": "0.2.3",
  "identifier": "dev.flaredeck.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FlareDeck",
        "width": 1440,
        "height": 960,
        "minWidth": 1040,
        "minHeight": 720,
        "resizable": true,
        "backgroundColor": "#0a0a0f"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdEOEQzMzEwMjU3QTc0MQpSV1JCcDFjQ01kUFlCeWlKTURycitqeVljZ0h0Sytyb3IwcFVtQkFLMUkxRDA4Z0o0MVJTWFdUVgo=",
      "endpoints": [
        "https://www.flaredeck.dev/latest.json"
      ]
    }
  }
}
